{
  "expo": {
    "name": "GraminKartMobile",
    "slug": "GraminKartMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "graminkartmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.kokok1.GraminKartMobile",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#2d9e2d"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kokok1.GraminKartMobile",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2d9e2d",
          "android": {
            "image": "./assets/images/icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de02c92c-e729-4985-9af8-d42cae78b228"
      }
    }
  }
}